{
  "name": "actually.mi",
  "description": "actually-mi monorepo: backend-api, frontend-ui",
  "version": "0.1.6",
  "private": true,
  "scripts": {
    "be:build": "nx build backend",
    "be:kill": "npx kill-port 8080",
    "be:start:dev": "nx serve backend",
    "be:start:prod": "nx build backend && node dist/apps/backend/main.js",
    "be:test": "nx test backend --forceExit",
    "be:test:coverage": "nx test backend --coverage --forceExit",
    "be:test:watch": "nx test backend --watch",
