    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/node": "^23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/react": "^23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
