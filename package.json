    "@testing-library/react": "16.3.0",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-jest": "~30.3.0",
    "esbuild": "^0.27.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.4.1",
    "jest-environment-node": "~30.4.1",
    "jest-util": "~30.3.0",
    "jiti": "2.4.2",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "prettier": "^3.8.4",
    "sass": "^1.97.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.0"
  },
  "workspaces": [
    "apps/*",
    "react-frontend"
  ],
  "lint-staged": {
    "apps/backend/src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3"
